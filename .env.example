# LLM API Keys (多个 Key 用逗号分隔)
# Moonshot (月之暗面 Kimi)
MOONSHOT_API_KEYS=your_moonshot_key_here

# Deepseek (深度求索)
DEEPSEEK_API_KEYS=your_deepseek_key_here

# Doubao (字节豆包)
DOUBAO_API_KEYS=your_doubao_key_here

# Zhipu AI (智谱清言)
ZHIPU_API_KEYS=your_zhipu_key_here

# Gemini (Google)
GEMINI_API_KEYS=your_gemini_key1,your_gemini_key2

# 火山引擎（用于文生图服务）
VOLC_ACCESS_KEY=your_volc_access_key
VOLC_SECRET_KEY=your_volc_secret_key

# ============================================================
# 国际财经新闻 API Keys（可选，未配置的数据源自动跳过）
# ============================================================

# Finnhub — 聚合 Reuters/CNBC 等主流财经媒体新闻及分析师推荐数据
# 免费层：60 calls/min，提供 /api/v1/news、/api/v1/company-news、/stock/recommendation 等端点
# 注册获取：https://finnhub.io/register （邮箱注册即可，无需信用卡）
FINNHUB_API_KEY=your_finnhub_api_key

# NewsAPI — 覆盖 Bloomberg/Reuters/CNBC/Financial Times/WSJ 等全球财经媒体
# 免费开发者层：100 requests/day，支持按关键词和来源筛选
# 注册获取：https://newsapi.org/register （邮箱注册即可）
NEWSAPI_API_KEY=your_newsapi_api_key

# Alpha Vantage — 提供 NEWS_SENTIMENT 端点，含新闻及情绪分析评分
# 免费层：25 requests/day，支持按股票代码和主题过滤
# 注册获取：https://www.alphavantage.co/support/#api-key （邮箱注册即可）
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Marketaux — 金融新闻 API，带情绪分析标签（看多/看空/中性）
# 免费层：100 requests/day，支持按股票代码和语言筛选
# 注册获取：https://www.marketaux.com/register （邮箱注册即可）
MARKETAUX_API_KEY=your_marketaux_api_key

# ============================================================
# 投行研报 API Keys（可选，Tier 3 付费源，大部分数据源无需 API Key）
# Tier 1（Finnhub + Yahoo Finance）和 Tier 2（Finviz + Zacks）均为免费源
# ============================================================

# Benzinga — 分析师评级 API，提供实时升降级数据（Tier 3，需付费订阅）
# 注册获取：https://www.benzinga.com/apis （需付费 Pro 计划）
BENZINGA_API_KEY=your_benzinga_api_key

# Seeking Alpha — 分析师文章和评级数据（Tier 3，部分免费）
# 注册获取：https://seekingalpha.com/api （部分端点免费，高级功能需订阅）
SEEKING_ALPHA_API_KEY=your_seeking_alpha_api_key

# ============================================================
# 数据库配置
# ============================================================

# DATABASE_URL — 数据库连接字符串
# SQLite（默认，开发环境推荐）：sqlite+aiosqlite:///./data/platform.db
# PostgreSQL（生产环境推荐）：postgresql+asyncpg://user:password@localhost:5432/platform_db
# 如不配置，默认使用 SQLite 存储在 data/platform.db
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db

# ============================================================
# 其他可选 Token
# ============================================================

# Tushare — A 股数据接口（可选，免费层需注册获取 Token）
# 注册获取：https://tushare.pro/register （手机号注册，免费层积分有限）
TUSHARE_TOKEN=your_tushare_token

# ============================================================
# 说明
# ============================================================
# 1. 所有 API Keys 都是可选的，至少配置一个 LLM 厂商的 Key 即可使用基础功能
# 2. 多个 LLM Key 用英文逗号分隔，系统会自动轮询使用
# 3. VOLC 配置用于图片生成功能，如不需要可不配置
# 4. 国际财经新闻 API Key 均可免费注册获取，未配置的数据源在采集时自动跳过
# 5. 投行研报 Tier 1/2 数据源（Finnhub 推荐 + Yahoo Finance + Finviz + Zacks）无需额外 API Key（Finnhub 复用上方国际新闻的 Key）
# 6. 配置完成后，将本文件重命名为 .env
