])
const isLoadingData = ref(false)

// Agent信息状态
const agentInfo = ref({
  agent_name: '',
  used_llm: false,
  cache_hit: false,
  llm_reasoning: '',  // LLM生成的内容片段
  is_thinking: false,  // 是否正在思考
  thinking_step: ''   // 当前思考步骤
})

